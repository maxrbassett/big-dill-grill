---
import Layout from '@layouts/Layout.astro';
import Nav from '@components/Nav.astro';
import OrderMenu from '@components/OrderMenu.astro';
import CartDrawer from '@components/CartDrawer.astro';
import SiteFooter from '@components/SiteFooter.astro';
import * as site from '@data/site';

const title = `Order Online for Pickup | ${site.name}`;
const description = `Order pickup from ${site.name} in ${site.address.city}, ${site.address.state}. Browse the menu, build your order, and pick it up. ${site.hoursSummary}.`;
---
<Layout title={title} description={description}>
  <Nav active="order" />
  <main>
    <!-- Page header -->
    <section class="bg-pickle-700 py-12 text-cream sm:py-16">
      <div class="mx-auto max-w-5xl px-4 sm:px-6">
        <p class="font-display text-sm font-bold uppercase tracking-[0.18em] text-gold-300">Pickup ordering</p>
        <h1 class="mt-2 font-display text-4xl font-bold text-cream sm:text-5xl">Order Online</h1>
        <p class="mt-3 max-w-2xl text-pickle-100/90">
          Build your order below and pick it up hot at {site.address.street}. {site.hoursSummary}.
        </p>
        <div class="mt-5 flex flex-wrap items-center gap-3">
          <button type="button" data-cart-open class="inline-flex items-center gap-2 rounded-full bg-gold-400 px-5 py-2.5 text-sm font-bold text-pickle-900 hover:bg-gold-300">
            View order
            <span data-cart-badge class="hidden rounded-full bg-barn-500 px-2 py-0.5 text-xs text-cream"><span data-cart-count>0</span></span>
          </button>
          <a href={`tel:${site.phoneTel}`} class="inline-flex items-center gap-2 rounded-full border border-cream/40 px-5 py-2.5 text-sm font-bold text-cream hover:bg-pickle-600">
            Or call {site.phone}
          </a>
        </div>
        <p class="mt-4 inline-block rounded-lg bg-pickle-900/40 px-4 py-2.5 text-xs leading-snug text-pickle-100/90">
          <span class="font-bold uppercase tracking-wide text-gold-300">Preview</span> — {site.ordering.notice}
        </p>
      </div>
    </section>

    <OrderMenu />
  </main>

  <SiteFooter />

  <!-- Mobile sticky "view order" bar -->
  <div class="fixed inset-x-0 bottom-0 z-30 border-t border-pickle-700 bg-pickle-800/95 px-4 py-2.5 backdrop-blur md:hidden">
    <button type="button" data-cart-open class="flex w-full items-center justify-between rounded-full bg-barn-500 px-5 py-3 font-bold text-cream active:bg-barn-600">
      <span>View your order</span>
      <span data-cart-badge class="hidden rounded-full bg-pickle-900/40 px-2.5 py-0.5 text-sm"><span data-cart-count>0</span> items</span>
    </button>
  </div>
  <div class="h-16 md:hidden" aria-hidden="true"></div>

  <CartDrawer />
</Layout>
