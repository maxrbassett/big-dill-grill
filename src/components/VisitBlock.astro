---
import * as site from '@data/site';
---
<section id="visit" class="scroll-mt-20 bg-cream py-16 sm:py-24">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="max-w-2xl">
      <p class="font-display text-sm font-bold uppercase tracking-[0.18em] text-barn-500">Come on by</p>
      <h2 class="mt-2 font-display text-4xl font-bold text-pickle-700 sm:text-5xl">Visit Us</h2>
      <p class="mt-4 text-ink-soft">
        Find us in Kershaw, South Carolina. Call ahead to order, or drop in — we’d love to see you.
      </p>
    </div>

    <div class="mt-10 grid gap-8 lg:grid-cols-2">
      <!-- Left: details + hours -->
      <div class="space-y-6">
        <div class="grid gap-4 sm:grid-cols-2">
          <div class="rounded-[var(--radius-card)] border border-line bg-paper p-5 shadow-sm">
            <h3 class="font-display text-sm font-bold uppercase tracking-wide text-pickle-600">Address</h3>
            <address class="mt-2 not-italic text-ink-soft">
              {site.address.street}<br />
              {site.address.city}, {site.address.state} {site.address.zip}
            </address>
            <a href={site.directionsUrl} target="_blank" rel="noopener" class="mt-3 inline-flex items-center gap-1.5 text-sm font-semibold text-pickle-600 underline-offset-2 hover:underline">
              Get directions
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M7 17 17 7M9 7h8v8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
          <div class="rounded-[var(--radius-card)] border border-line bg-paper p-5 shadow-sm">
            <h3 class="font-display text-sm font-bold uppercase tracking-wide text-pickle-600">Phone</h3>
            <a href={`tel:${site.phoneTel}`} class="mt-2 inline-block font-display text-2xl font-bold text-pickle-700 hover:text-barn-600">{site.phone}</a>
            <a href={`tel:${site.phoneTel}`} class="mt-3 block w-full rounded-full bg-barn-500 px-4 py-2.5 text-center text-sm font-bold text-cream transition-colors hover:bg-barn-600">
              Call to Order
            </a>
          </div>
        </div>

        <!-- Hours (confirmed) -->
        <div>
          <div class="flex items-center justify-between">
            <h3 class="font-display text-sm font-bold uppercase tracking-wide text-pickle-600">Hours</h3>
            <span class="text-xs font-semibold text-ink-soft/70">{site.hoursSummary}</span>
          </div>
          <dl class="mt-3 divide-y divide-line overflow-hidden rounded-[var(--radius-card)] border border-line bg-paper" id="hours-list">
            {site.hoursOrder.map((k) => (
              <div class="flex items-center justify-between px-5 py-2.5" data-day={k}>
                <dt class="font-semibold text-pickle-700">{site.hours[k].label}</dt>
                <dd class:list={['text-sm', site.hours[k].open === null ? 'text-ink-soft/60' : 'text-ink-soft']}>{site.hours[k].display}</dd>
              </div>
            ))}
          </dl>
        </div>

        <!-- Map embed (keyless) -->
        <div class="overflow-hidden rounded-[var(--radius-card)] border border-line shadow-sm">
          <iframe
            title={`Map to ${site.name}`}
            src={site.mapEmbedUrl}
            width="100%"
            height="280"
            style="border:0; display:block;"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen
          ></iframe>
        </div>
      </div>

      <!-- Right: demo contact form -->
      <div class="rounded-[var(--radius-card)] border border-line bg-paper p-6 shadow-sm sm:p-8">
        <div class="mb-4 inline-flex items-center gap-2 rounded-full bg-gold-400/25 px-3 py-1 text-xs font-bold uppercase tracking-wide text-wood-600">
          Preview form
        </div>
        <h3 class="font-display text-2xl font-bold text-pickle-700">Send us a message</h3>
        <p class="mt-2 text-sm text-ink-soft">
          This is a demo form — it isn’t connected yet. For now, the fastest way to reach us is to call.
        </p>
        <form class="mt-5 space-y-4" data-demo={`Thanks! This contact form is part of the website preview and isn’t connected yet. Please call us at ${site.phone} to place an order or ask a question.`} aria-label="Contact (demo)">
          <div>
            <label for="cf-name" class="block text-sm font-semibold text-ink">Name</label>
            <input id="cf-name" name="name" type="text" autocomplete="name" class="mt-1 w-full rounded-lg border border-line bg-cream/60 px-3.5 py-2.5 text-ink placeholder:text-ink-soft/50 focus:border-pickle-500 focus:bg-paper focus:outline-none" placeholder="Your name" />
          </div>
          <div>
            <label for="cf-phone" class="block text-sm font-semibold text-ink">Phone</label>
            <input id="cf-phone" name="phone" type="tel" autocomplete="tel" class="mt-1 w-full rounded-lg border border-line bg-cream/60 px-3.5 py-2.5 text-ink placeholder:text-ink-soft/50 focus:border-pickle-500 focus:bg-paper focus:outline-none" placeholder="(803) 555-0123" />
          </div>
          <div>
            <label for="cf-msg" class="block text-sm font-semibold text-ink">Message</label>
            <textarea id="cf-msg" name="message" rows="4" class="mt-1 w-full rounded-lg border border-line bg-cream/60 px-3.5 py-2.5 text-ink placeholder:text-ink-soft/50 focus:border-pickle-500 focus:bg-paper focus:outline-none" placeholder="Tell us what you’d like to order or ask…"></textarea>
          </div>
          <button type="submit" class="w-full rounded-full bg-pickle-600 px-5 py-3 font-bold text-cream transition-colors hover:bg-pickle-700">
            Send message
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  // Highlight today's row in the hours list. Purely visual enhancement.
  const keys = ['sunday', 'monday', 'tuesday', 'wednesday', 'thursday', 'friday', 'saturday'];
  const todayKey = keys[new Date().getDay()];
  const row = document.querySelector(`#hours-list [data-day="${todayKey}"]`);
  if (row) {
    row.classList.add('bg-pickle-50');
    const badge = document.createElement('span');
    badge.textContent = 'Today';
    badge.className = 'ml-2 rounded-full bg-pickle-500 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wide text-cream align-middle';
    row.querySelector('dt')?.appendChild(badge);
  }
</script>
