---
import { Image } from 'astro:assets';
import * as site from '@data/site';
import storefront from '@assets/storefront.jpg';
import logoBadge from '@assets/logo-badge.jpg';
// Background: the restaurant's own storefront photo, faded behind a deep pickle
// overlay for legibility. Showpiece: their real building logo, framed like a sign.
---
<section id="top" class="relative overflow-hidden bg-pickle-800 text-cream">
  <!-- Storefront photo background (faded) -->
  <Image
    src={storefront}
    alt=""
    aria-hidden="true"
    widths={[768, 1280, 1600]}
    sizes="100vw"
    class="absolute inset-0 h-full w-full object-cover object-center opacity-45"
    loading="eager"
  />
  <!-- Color overlays for contrast + brand warmth -->
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div class="absolute inset-0 bg-gradient-to-br from-pickle-800/75 via-pickle-800/65 to-pickle-900/85"></div>
    <div class="absolute -right-24 -top-24 h-96 w-96 rounded-full bg-gold-500/20 blur-3xl"></div>
    <div class="absolute -bottom-32 -left-24 h-96 w-96 rounded-full bg-barn-500/20 blur-3xl"></div>
  </div>

  <div class="relative mx-auto grid max-w-6xl items-center gap-10 px-4 py-16 sm:px-6 sm:py-20 md:grid-cols-[1.1fr_0.9fr] md:py-24">
    <div class="animate-rise">
      <p class="inline-flex items-center gap-2 rounded-full border border-pickle-300/40 bg-pickle-900/40 px-3 py-1 text-xs font-bold uppercase tracking-[0.16em] text-gold-300">
        {site.heroEyebrow}
      </p>
      <h1 class="mt-5 font-display text-5xl font-bold leading-[1.02] text-cream sm:text-6xl">
        The Big Dill Grill
      </h1>
      <p class="mt-4 font-display text-2xl font-semibold text-gold-300 sm:text-3xl">
        {site.tagline}
      </p>
      <p class="mt-3 text-base font-semibold uppercase tracking-[0.14em] text-pickle-100">
        {site.slogan}
      </p>
      <p class="mt-5 max-w-xl text-base leading-relaxed text-pickle-100/90 sm:text-lg">
        {site.heroSubhead}
      </p>

      <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
        <a
          href={site.orderUrl}
          class="inline-flex items-center justify-center gap-2 rounded-full bg-barn-500 px-7 py-3.5 text-base font-bold text-cream shadow-lg transition-colors hover:bg-barn-400"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M3 6h18M3 6l1.5 12.5a2 2 0 0 0 2 1.5h11a2 2 0 0 0 2-1.5L21 6M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Order Online for Pickup
        </a>
        <a
          href={`tel:${site.phoneTel}`}
          class="inline-flex items-center justify-center gap-2 rounded-full border-2 border-gold-400 bg-transparent px-7 py-3.5 text-base font-bold text-gold-300 transition-colors hover:bg-gold-400 hover:text-pickle-900"
        >
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Call to Order
        </a>
      </div>
      <p class="mt-4">
        <a href="#specials" class="inline-flex items-center gap-1.5 text-sm font-semibold text-pickle-100 underline-offset-4 hover:text-gold-300 hover:underline">
          or see this week’s specials
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true"><path d="M12 5v14M5 12l7 7 7-7" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </p>

      <p class="mt-5 text-sm font-semibold text-pickle-200">
        {site.hoursSummary}
      </p>
    </div>

    <div class="relative mx-auto w-full max-w-sm">
      <div class="absolute inset-0 -rotate-3 rounded-[2rem] bg-gold-400/20"></div>
      <div class="relative rounded-[2rem] border border-cream/20 bg-cream p-4 shadow-2xl">
        <Image
          src={logoBadge}
          alt={`${site.name} logo — the “Big Dill Restaurant Grill” pickle-cowboy crest`}
          widths={[320, 480, 640]}
          sizes="(min-width: 768px) 380px, 75vw"
          class="h-auto w-full rounded-2xl"
        />
      </div>
    </div>
  </div>
</section>
