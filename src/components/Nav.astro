---
import { Image } from 'astro:assets';
import * as site from '@data/site';
import logoBadge from '@assets/logo-badge.jpg';
const { active } = Astro.props as { active?: string };
---
<header class="sticky top-0 z-40 border-b border-line bg-cream/90 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-2.5 sm:px-6">
    <a href="/" class="flex shrink-0 items-center gap-2.5">
      <Image src={logoBadge} alt="" aria-hidden="true" width={88} height={88} class="-my-1 h-11 w-11 rounded-lg object-cover" />
      <span class="font-display text-base font-bold leading-none text-pickle-700 sm:text-lg">
        The Big Dill Grill
      </span>
    </a>

    <nav class="hidden items-center gap-7 md:flex" aria-label="Primary">
      {site.nav.map((item) => (
        <a href={item.href} class="text-sm font-semibold text-ink-soft transition-colors hover:text-pickle-600">{item.label}</a>
      ))}
      <a
        href={site.orderUrl}
        class:list={['text-sm font-semibold transition-colors hover:text-pickle-600', active === 'order' ? 'text-pickle-700 underline underline-offset-4' : 'text-ink-soft']}
      >Order Online</a>
    </nav>

    <div class="flex shrink-0 items-center gap-2">
      <!-- Cart button -->
      <button type="button" data-cart-open class="relative inline-flex h-10 w-10 items-center justify-center rounded-lg border border-line text-pickle-700 hover:bg-cream-deep" aria-label="View your pickup order">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <span data-cart-badge class="absolute -right-1.5 -top-1.5 hidden min-w-[18px] rounded-full bg-barn-500 px-1 text-center text-[11px] font-bold leading-[18px] text-cream"><span data-cart-count>0</span></span>
      </button>
      <!-- Order Online (primary; hidden on the smallest screens — covered by the menu + bottom bar) -->
      <a href={site.orderUrl} class="hidden items-center gap-1.5 rounded-full bg-barn-500 px-4 py-2 text-sm font-bold text-cream shadow-sm transition-colors hover:bg-barn-600 sm:inline-flex">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M3 6h18M3 6l1.5 12.5a2 2 0 0 0 2 1.5h11a2 2 0 0 0 2-1.5L21 6M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Order Online
      </a>
      <button
        type="button"
        id="nav-toggle"
        class="inline-flex h-10 w-10 items-center justify-center rounded-lg border border-line text-pickle-700 md:hidden"
        aria-expanded="false"
        aria-controls="nav-mobile"
      >
        <span class="sr-only">Toggle menu</span>
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M3 6h18M3 12h18M3 18h18" stroke-linecap="round"/></svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="nav-mobile" class="hidden border-t border-line bg-cream px-4 pb-4 pt-3 md:hidden">
    <ul class="flex flex-col gap-1">
      {site.nav.map((item) => (
        <li><a href={item.href} class="block rounded-lg px-3 py-2.5 text-sm font-semibold text-ink-soft hover:bg-cream-deep" data-nav-link>{item.label}</a></li>
      ))}
      <li><a href={site.orderUrl} class="block rounded-lg px-3 py-2.5 text-sm font-semibold text-ink-soft hover:bg-cream-deep" data-nav-link>Order Online</a></li>
      <li><a href={`tel:${site.phoneTel}`} class="block rounded-lg px-3 py-2.5 text-sm font-bold text-barn-600 hover:bg-cream-deep">Call to Order — {site.phone}</a></li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('nav-mobile');
  function setOpen(open: boolean) {
    toggle?.setAttribute('aria-expanded', String(open));
    menu?.classList.toggle('hidden', !open);
  }
  toggle?.addEventListener('click', () => {
    setOpen(toggle.getAttribute('aria-expanded') !== 'true');
  });
  menu?.querySelectorAll('[data-nav-link]').forEach((link) => {
    link.addEventListener('click', () => setOpen(false));
  });
</script>
