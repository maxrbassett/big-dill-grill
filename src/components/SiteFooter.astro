---
import { Image } from 'astro:assets';
import * as site from '@data/site';
import logoBadge from '@assets/logo-badge.jpg';
const year = new Date().getFullYear();
---
<footer class="bg-pickle-900 text-pickle-100">
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      <div class="sm:col-span-2 lg:col-span-1">
        <div class="flex items-center gap-3">
          <Image src={logoBadge} alt="" aria-hidden="true" width={104} height={104} class="h-14 w-14 rounded-xl object-cover ring-1 ring-pickle-300/30" />
          <span class="font-display text-xl font-bold text-cream">The Big Dill Grill</span>
        </div>
        <p class="mt-3 font-display text-sm font-semibold uppercase tracking-[0.12em] text-gold-300">{site.slogan}</p>
        <p class="mt-2 text-sm text-pickle-200/80">{site.tagline}</p>
      </div>

      <div>
        <h3 class="font-display text-sm font-bold uppercase tracking-wide text-gold-300">Visit</h3>
        <address class="mt-3 not-italic text-sm leading-relaxed text-pickle-200/90">
          {site.address.street}<br />
          {site.address.city}, {site.address.state} {site.address.zip}
        </address>
        <p class="mt-2 text-sm text-pickle-200/90">{site.hoursSummary}</p>
      </div>

      <div>
        <h3 class="font-display text-sm font-bold uppercase tracking-wide text-gold-300">Order &amp; Reach Us</h3>
        <a href={`tel:${site.phoneTel}`} class="mt-3 block font-display text-2xl font-bold text-cream hover:text-gold-300">{site.phone}</a>
        <a href={site.facebookUrl} target="_blank" rel="noopener" class="mt-3 inline-flex items-center gap-2 text-sm font-semibold text-pickle-100 hover:text-gold-300">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.78-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.78l-.44 2.89h-2.34v6.99A10 10 0 0 0 22 12z"/></svg>
          Find us on Facebook
        </a>
      </div>

      <div>
        <h3 class="font-display text-sm font-bold uppercase tracking-wide text-gold-300">Explore</h3>
        <ul class="mt-3 space-y-2 text-sm">
          {site.nav.map((item) => (
            <li><a href={item.href} class="text-pickle-200/90 hover:text-cream">{item.label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-10 flex flex-col gap-2 border-t border-pickle-700/60 pt-6 text-xs text-pickle-300/70 sm:flex-row sm:items-center sm:justify-between">
      <p>© {year} {site.name}. All rights reserved.</p>
      <p>Website preview · Good Food. Good People. Good Times.</p>
    </div>
  </div>
</footer>
