---
import * as site from '@data/site';
// Sticky bottom call bar — mobile only. A persistent, thumb-friendly way to order.
---
<div class="fixed inset-x-0 bottom-0 z-30 border-t border-pickle-700 bg-pickle-800/95 px-4 py-2.5 backdrop-blur md:hidden">
  <div class="flex items-center gap-2.5">
    <a
      href={site.orderUrl}
      class="inline-flex flex-1 items-center justify-center gap-2 rounded-full bg-barn-500 px-4 py-2.5 text-sm font-bold text-cream shadow-lg active:bg-barn-600"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M3 6h18M3 6l1.5 12.5a2 2 0 0 0 2 1.5h11a2 2 0 0 0 2-1.5L21 6M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      Order Online
    </a>
    <a
      href={`tel:${site.phoneTel}`}
      class="inline-flex flex-1 items-center justify-center gap-2 rounded-full border border-cream/40 px-4 py-2.5 text-sm font-bold text-cream active:bg-pickle-700"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z" stroke-linecap="round" stroke-linejoin="round"/></svg>
      Call
    </a>
  </div>
</div>
